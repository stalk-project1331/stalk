{
  "name": "STALK",
  "version": "0.2.9",
  "description": "Osint Assistant",
  "private": true,
  "main": "electron/main.js",
  "author": "t.me/cyberstalker007",
  "scripts": {
    "react": "vite",
    "electron": "wait-on http://localhost:5173 && electron electron/main.js",
    "start": "concurrently \"npm:react\" \"npm:electron\"",
    "build": "vite build",
    "package": "npm run build && electron-builder --win --x64",
    "release": "npm run build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "exifr": "^7.0.0",
    "framer-motion": "^10.12.16",
    "google-libphonenumber": "^3.2.44",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.278.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@headlessui/react": "^1.7.19",
    "@tailwindcss/forms": "^0.5.4",
    "@tailwindcss/typography": "^0.5.9",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cyberstalker.stalk",
    "productName": "STALK",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/*.map",
      "!**/src/**",
      "!**/node_modules/.cache/**",
      "!backend/**"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/STALK.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "STALK",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "stalk-project1331",
      "repo": "stalk"
    }
  }
}
